flowchart LR
    subgraph TK["Token Authority Context  ·  Core Domain"]
        direction TB
        tk_pkg["@spec-kitty/tokens\n--sk-* custom properties"]
        tk_rule["Invariant:\nNo value defined outside\nthis context"]
        tk_src["Source:\nClaude Design ref  +\nlive site reconciliation"]
        tk_src --> tk_pkg
    end

    subgraph CL["Component Library Context  ·  Supporting"]
        direction TB
        angular_pkg["@spec-kitty/angular\nAngular LTS adapter"]
        html_pkg["@spec-kitty/html-js\nframework-agnostic\nprimitives"]
        cl_rule["Invariant:\nRender via --sk-* only\nNo value override"]
    end

    subgraph DOC["Documentation + Visual Regression  ·  Supporting"]
        direction TB
        sb["Storybook\nMulti-framework renderer"]
        pages_out["GitHub Pages\npublic URL"]
        baseline["Visual baseline\nCI regression snapshots"]
        sb --> pages_out
        sb --> baseline
    end

    subgraph DT["Doctrine Bundle Context  ·  Supporting"]
        direction TB
        sk_d01["SK-D01\nToken Authority Directive"]
        sk_d02["SK-D02\nIllustration Boundary Directive"]
        voice["sk-brand-voice\nstyleguide"]
        visual["sk-visual-identity\nstyleguide"]
        drg_graph["graph.yaml\norg-layer stub  #832"]
    end

    subgraph SC["Supply Chain + Release  ·  Generic"]
        direction TB
        audit["npm audit\nhigh-severity gate"]
        sbom["CycloneDX SBOM\nat release"]
        prov["npm --provenance\nattested publish"]
        dep["Dependabot\nweekly auto-PRs"]
    end

    TK -->|"peer dep  (values by ref)"| CL
    CL -->|"stories"| DOC
    TK -->|"token catalogue"| DOC
    TK -->|"feeds SK-D01"| DT
    DOC -->|"visual baseline"| SC
    CL -->|"dist artifacts"| SC
    TK -->|"dist artifact"| SC

    classDef core fill:#1a1a08,stroke:#F5C518,color:#F5C518,stroke-width:2px
    classDef support fill:#14202E,stroke:#A9C7E8,color:#A9C7E8,stroke-width:1.5px
    classDef generic fill:#1C1C20,stroke:#B8A9E0,color:#B8A9E0,stroke-width:1.5px

    class TK core
    class CL,DOC,DT support
    class SC generic
