{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": {
    "analytics": false
  },
  "projects": {
    "storybook": {
      "projectType": "application",
      "schematics": {},
      "root": "apps/storybook",
      "sourceRoot": "apps/storybook/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:browser",
          "options": {
            "outputPath": "apps/storybook/dist",
            "index": "apps/storybook/src/index.html",
            "main": "apps/storybook/src/main.ts",
            "polyfills": ["zone.js"],
            "tsConfig": "apps/storybook/.storybook/tsconfig.json",
            "inlineStyleLanguage": "css",
            "assets": [],
            "styles": [],
            "scripts": []
          }
        },
        "storybook": {
          "builder": "@storybook/angular:start-storybook",
          "options": {
            "configDir": "apps/storybook/.storybook",
            "browserTarget": "storybook:build",
            "compodoc": false,
            "port": 4400
          }
        },
        "build-storybook": {
          "builder": "@storybook/angular:build-storybook",
          "options": {
            "configDir": "apps/storybook/.storybook",
            "browserTarget": "storybook:build",
            "compodoc": false,
            "outputDir": "apps/storybook/storybook-static"
          }
        }
      }
    }
  }
}
